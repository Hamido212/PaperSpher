---
import { SITE, LINKS } from "@consts"
import { cn } from "@lib/utils"
const { pathname } = Astro.url
const subpath = pathname.match(/[^/]+/g)
import Container from "@components/Container.astro"
---

<header id="header" class="fixed top-0 w-full h-14 z-50">
  <Container size="md">
    <div class="relative h-full w-full flex items-center justify-between">

      <!-- Logo / Brand -->
      <a
        href="/"
        class="flex items-center gap-2 text-sm font-semibold tracking-tight hover:opacity-80 transition-opacity duration-200"
        style="color: var(--color-text);"
      >
        <span class="hidden sm:block">{SITE.AUTHOR}</span>
        <span class="block sm:hidden">hy</span>
      </a>

      <!-- Center nav — minimal, text-based links -->
      <nav class="hidden md:flex items-center gap-6 text-sm" style="color: var(--color-text-muted);">
        {
          LINKS.filter(l => l.HREF !== "/").map((LINK) => {
            const isActive = pathname === LINK.HREF || "/" + subpath?.[0] === LINK.HREF
            return (
              <a
                href={LINK.HREF}
                class={cn(
                  "relative py-1 transition-colors duration-200",
                  "hover:text-[var(--color-text)]",
                  isActive
                    ? "text-[var(--color-text)] font-medium"
                    : "text-[var(--color-text-muted)]"
                )}
              >
                {LINK.TEXT}
                {isActive && (
                  <span
                    class="absolute -bottom-0.5 left-0 right-0 h-px"
                    style="background-color: var(--color-accent);"
                  />
                )}
              </a>
            )
          })
        }
      </nav>

      <!-- Right actions -->
      <div class="flex items-center gap-1">
        <a
          href="/search"
          aria-label={`Search on ${SITE.TITLE}`}
          class={cn(
            "hidden md:flex size-8 rounded-md p-1.5 items-center justify-center",
            "hover:bg-black/5 dark:hover:bg-white/10",
            "stroke-current transition-colors duration-200",
            "border",
          )}
          style="border-color: var(--color-border);"
        >
          <svg class="size-full"><use href="/ui.svg#search"></use></svg>
        </a>

        <a
          href="/rss.xml"
          target="_blank"
          aria-label={`RSS feed for ${SITE.TITLE}`}
          class={cn(
            "hidden md:flex size-8 rounded-md p-1.5 items-center justify-center",
            "hover:bg-black/5 dark:hover:bg-white/10",
            "stroke-current transition-colors duration-200",
            "border",
          )}
          style="border-color: var(--color-border);"
        >
          <svg class="size-full"><use href="/ui.svg#rss"></use></svg>
        </a>

        <button
          id="header-theme-button"
          aria-label="Toggle light and dark theme"
          class={cn(
            "hidden md:flex size-8 rounded-md p-1.5 items-center justify-center",
            "hover:bg-black/5 dark:hover:bg-white/10",
            "stroke-current transition-colors duration-200",
            "border",
          )}
          style="border-color: var(--color-border);"
        >
          <svg class="size-full block dark:hidden"><use href="/ui.svg#sun"></use></svg>
          <svg class="size-full hidden dark:block"><use href="/ui.svg#moon"></use></svg>
        </button>

        <button
          id="header-drawer-button"
          aria-label="Toggle drawer"
          class={cn(
            "flex md:hidden size-8 rounded-md p-1.5 items-center justify-center",
            "hover:bg-black/5 dark:hover:bg-white/10",
            "stroke-current transition-colors duration-200",
            "border",
          )}
          style="border-color: var(--color-border);"
        >
          <svg id="drawer-open" class="size-full"><use href="/ui.svg#menu"></use></svg>
          <svg id="drawer-close" class="size-full"><use href="/ui.svg#x"></use></svg>
        </button>
      </div>

    </div>
  </Container>
</header>

<style>
  #header-drawer-button > #drawer-open {
    @apply block;
  }

  #header-drawer-button > #drawer-close {
    @apply hidden;
  }

  #header-drawer-button.open > #drawer-open {
    @apply hidden;
  }

  #header-drawer-button.open > #drawer-close {
    @apply block;
  }
</style>

<script is:inline>
  function toggleDrawer() {
    const drawer = document.getElementById("drawer")
    const drawerButton = document.getElementById("header-drawer-button")
    drawer?.classList.toggle("open")
    drawerButton?.classList.toggle("open")
  }

  function initializeDrawerButton() {
    const drawerButton = document.getElementById("header-drawer-button")
    drawerButton?.addEventListener("click", toggleDrawer)
  }

  document.addEventListener("astro:after-swap", initializeDrawerButton)
  initializeDrawerButton()
</script>
